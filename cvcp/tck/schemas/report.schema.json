{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TCK Compliance Report Schema",
  "type": "object",
  "properties": {
    "sdk": { "type": "string" },
    "protocol_version": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "summary": {
      "type": "object",
      "properties": {
        "total": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "skipped": { "type": "integer" }
      },
      "required": ["total", "passed", "failed", "skipped"]
    },
    "results": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "required": ["sdk", "protocol_version", "timestamp", "summary", "results"]
}
